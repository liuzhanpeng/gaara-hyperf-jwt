{
    "name": "lzpeng/gaara-hyperf-jwt",
    "description": "gaara-hyperf jwt authentication extension.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "GaaraHyperf\\JWT\\": "src/"
        }
    },
    "authors": [
        {
            "name": "liuzhanpeng",
            "email": "liuzhanpeng@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "lzpeng/gaara-hyperf": "dev-master",
        "lcobucci/jwt": "^5.6",
        "lcobucci/clock": "^3.5"
    },
    "require-dev": {
        "pestphp/pest": "^2.36",
        "mockery/mockery": "^1.6",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "extra": {
        "hyperf": {
            "config": "GaaraHyperf\\JWT\\ConfigProvider"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
